# Copy this file to .env.production and fill in every value before deploying.
# Never commit .env.production to git.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_THIS_use_a_strong_random_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_64_char_random_string
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=CHANGE_THIS_different_64_char_string
JWT_REFRESH_EXPIRES_IN=7d

# ── SendGrid ──────────────────────────────────────────────────────────────────
# 1. Sign up at sendgrid.com → Settings → API Keys → Create API Key (Full Access)
# 2. Verify sender: Settings → Sender Authentication → verify erp@adesoafrica.org
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx

EMAIL_FROM_NAME=ADESO ERP System
EMAIL_FROM_ADDRESS=erp@adesoafrica.org

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Azure Portal → Storage accounts → adesoerpdocs → Access keys
AZURE_STORAGE_ACCOUNT=adesoerpdocs
AZURE_STORAGE_KEY=your_storage_account_key
AZURE_STORAGE_CONTAINER=erp-documents

# ── App ───────────────────────────────────────────────────────────────────────
# Use http://20.83.156.15 initially; update to https://erp.adesoafrica.org after SSL setup
APP_URL=http://20.83.156.15
APP_NAME=ADESO ERP

# ── Global Admin ──────────────────────────────────────────────────────────────
GLOBAL_ADMIN_EMAIL=thussein@adesoafrica.org
GLOBAL_ADMIN_NAME=Tarish Hussein
SESSION_TIMEOUT_HOURS=8
