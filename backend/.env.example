# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/erp_db

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=erp-documents
R2_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@adesoafrica.org
SMTP_PASS=your_email_password
EMAIL_FROM_NAME=ADESO ERP System
EMAIL_FROM_ADDRESS=erp@adesoafrica.org

# App
APP_URL=http://localhost:3000
APP_NAME=ADESO ERP

# Global Admin
GLOBAL_ADMIN_EMAIL=thussein@adesoafrica.org
GLOBAL_ADMIN_NAME=Tarish Hussein

# Session
SESSION_TIMEOUT_HOURS=8
